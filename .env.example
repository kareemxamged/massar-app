# ===========================================
# Exam Management System - Environment Variables
# ===========================================

# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===========================================
# AI Configuration (Optional - for real AI features)
# ===========================================

# Set to 'true' to use real AI with multi-provider failover
# If false or not set, uses mock AI for testing
VITE_USE_REAL_AI=false

# ===========================================
# Supabase Edge Function Secrets (Required for real AI)
# These must be configured in Supabase Dashboard > Edge Functions > Secrets
# DO NOT add these to your frontend .env file - they belong in Supabase Secrets
# ===========================================

# Gemini API Key (Primary provider)
# Get from: https://ai.google.dev/
# GEMINI_API_KEY=your-gemini-api-key

# OpenAI API Key (Secondary provider)
# Get from: https://platform.openai.com/
# OPENAI_API_KEY=your-openai-api-key

# Anthropic API Key (Tertiary provider)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ===========================================
# AI Provider Priority Order (Default):
# 1. Gemini 1.5 Pro (Primary)
# 2. GPT-4o (Secondary)
# 3. Claude 3.5 Sonnet (Tertiary)
# ===========================================

# Note: All AI processing happens securely through Supabase Edge Functions
# API keys are NEVER exposed to the client-side
